{
  "description": "Auto-setup funnelwise package on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/setup.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
